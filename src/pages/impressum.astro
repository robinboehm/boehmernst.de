---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Impressum">
  <div class="page-container">
    <h1 class="page-title">Impressum</h1>

    <div class="impressum-content">
      <section>
        <h2>Angaben gemäß § 5 TMG</h2>
        <p>Dr.(CS) Ernst Böhm</p>
        <p>Stiftstraße 4</p>
        <p>59494 Soest</p>
      </section>

      <section>
        <h2>Kontakt</h2>
        <p>Telefon: <a href="tel:+4916017016920">0160 170 16 92</a></p>
        <p>E-Mail: <a href="mailto:dr.boehmernst@web.de">dr.boehmernst@web.de</a></p>
      </section>

      <section>
        <h2>Berufsrechtliche Angaben</h2>
        <p>Berufsbezeichnung: Arzt (verliehen in der Tschechischen Republik)</p>
        <p>Zuständige Kammer: Ärztekammer Westfalen-Lippe, Gartenstraße 210–214, 48147 Münster</p>
        <p>Berufsrechtliche Regelung: Berufsordnung für Ärztinnen und Ärzte der Ärztekammer Westfalen-Lippe</p>
        <p>Die Berufsordnung ist einsehbar unter: <a href="https://www.aekwl.de" target="_blank" rel="noopener noreferrer">www.aekwl.de</a></p>
      </section>

      <section>
        <h2>Hinweis zur Umsatzsteuer</h2>
        <p>
          Diese Website dient der privaten, nicht-gewerblichen Präsentation von Fotografien.
          Es besteht keine Umsatzsteuerpflicht im Sinne des § 19 UStG.
        </p>
      </section>

      <section>
        <h2>Urheberrecht</h2>
        <p>
          Alle Inhalte auf dieser Website unterliegen dem Urheberrecht und
          dürfen ohne schriftliche Genehmigung des Autors nicht weiterverwendet werden.
        </p>
      </section>

      <section>
        <h2>Haftungsausschluss</h2>
        <p>
          Trotz sorgfältiger inhaltlicher Kontrolle übernehme ich keine Haftung für
          die Inhalte externer Links. Für den Inhalt verlinkter Seiten sind
          ausschließlich deren Betreiber verantwortlich.
        </p>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
.impressum-content {
  max-width: 640px;
}

.impressum-content section {
  margin-bottom: 2rem;
}

.impressum-content h2 {
  font-size: 1rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 0.75rem;
}

.impressum-content p {
  color: var(--text-muted);
  line-height: 1.7;
  margin-bottom: 0.3rem;
}
</style>
